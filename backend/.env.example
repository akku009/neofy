# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USERNAME=root
DATABASE_PASSWORD=
DATABASE_NAME=neofy_development

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Sidekiq ────────────────────────────────────────────────────────────────────
SIDEKIQ_CONCURRENCY=5

# ── JWT / Devise ───────────────────────────────────────────────────────────────
DEVISE_JWT_SECRET_KEY=replace-with-a-strong-random-secret-min-32-chars
SECRET_KEY_BASE=replace-with-rails-credentials-secret-key-base

# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── CORS ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── App ────────────────────────────────────────────────────────────────────────
RAILS_ENV=development
RAILS_LOG_TO_STDOUT=true

# ── Domain / Routing ───────────────────────────────────────────────────────────
APP_HOST=neofy.com
TRUSTED_PROXIES=

# ── Email ──────────────────────────────────────────────────────────────────────
MAILER_FROM=noreply@neofy.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# ── Error Monitoring ───────────────────────────────────────────────────────────
SENTRY_DSN=

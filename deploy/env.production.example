# ─────────────────────────────────────────────────────────────────────────────
# Neofy — Production Environment Variables
# Copy to: /var/www/neofy/shared/config/.env
# Permissions: chmod 600 .env && chown deploy:deploy .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_NAME=neofy_production
DATABASE_USERNAME=neofy
DATABASE_PASSWORD=CHANGE_THIS_STRONG_DB_PASSWORD

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0

# ── Sidekiq ───────────────────────────────────────────────────────────────────
# Scale up for higher concurrency (match to DB pool size)
SIDEKIQ_CONCURRENCY=10

# ── Rails ─────────────────────────────────────────────────────────────────────
RAILS_ENV=production
RAILS_LOG_TO_STDOUT=true
RAILS_MAX_THREADS=5
WEB_CONCURRENCY=2          # number of Puma worker processes (2x CPU cores)
PORT=3000                  # only used if binding to TCP instead of Unix socket

# ── Security secrets (generate with: rails secret) ───────────────────────────
# NEVER commit real values — generate unique per environment
SECRET_KEY_BASE=GENERATE_WITH_rails_secret_COMMAND_64_CHARS_MIN
DEVISE_JWT_SECRET_KEY=GENERATE_RANDOM_32_CHAR_MIN_DIFFERENT_FROM_ABOVE

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_YOUR_LIVE_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_LIVE_STRIPE_PUBLISHABLE_KEY
# Get from Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SIGNING_SECRET

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Use SendGrid / Postmark / SES for production email delivery
MAILER_FROM=noreply@neofy.com
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=YOUR_SENDGRID_API_KEY

# ── Domain / Routing ──────────────────────────────────────────────────────────
APP_HOST=neofy.com
# Comma-separated trusted proxy IPs (add your Nginx server IP)
TRUSTED_PROXIES=127.0.0.1

# ── Error Monitoring ──────────────────────────────────────────────────────────
# Create a project at sentry.io → copy the DSN
SENTRY_DSN=https://YOUR_KEY@sentry.io/YOUR_PROJECT_ID

# ── Puma ─────────────────────────────────────────────────────────────────────
PUMA_MAX_THREADS=5
PUMA_MIN_THREADS=5
